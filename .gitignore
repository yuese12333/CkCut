# 忽略虚拟环境
.venv/

# 忽略 Python 编译缓存
__pycache__/
*.pyc
*.pyo

# 忽略原始语料和中间处理数据
data/raw_corpus/*
data/processed/*
data/HMM_train/*
data/evaluate/*

# 忽略 VS Code 本地配置
.vscode/

# BiLSTM-CRF 训练权重（体积较大，可重新训练生成）
# 同目录 char_vocab.json / train_history.json 建议保留入库
data/output_nn_crf_merged/*.pt
data/output_nn_crf_single/**/*.pt
